local const function GeneratePipeFourway(l: PipeLayer): typings.EntityPrototype = new typings.EntityPrototype {
    parent { "GasPipeFourway" }
    id = "GasPipeFourway\(l)"
    suffix = "Fourway, \(l)"
    components {
        new typings.NodeContainerComponent {
            nodes {
                ["pipe"] = new typings.PipeNode {
                    nodeGroupID = "Pipe"
                    pipeDirection = "Fourway"
                    layer = l
                }
            }
        }
        new typings.SpriteComponent {
            layers {
                new typings.PrototypeLayerData {
                    state = "pipeFourway_\(l)"
