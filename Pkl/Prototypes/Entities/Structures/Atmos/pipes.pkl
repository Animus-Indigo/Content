    parent { "GasPipeTJunction" }
    id = "GasPipeTJunction\(l)"
    suffix = "T-Junction, \(l)"
    components {
        new typings.NodeContainerComponent {
            nodes {
                ["pipe"] = new typings.PipeNode {
