local const function GenerateValve(l: PipeLayer): typings.EntityPrototype = new typings.EntityPrototype {
    parent { "GasValve" }
    id = "GasValve\(l)"
    suffix = "\(l)"
    components {
        new typings.SpriteComponent {
            layers {
                new typings.PrototypeLayerData {
                    sprite = "/Textures/Structures/Piping/Atmospherics/pipe.rsi"
                    state = "pipeStraight_\(l)"
                    map = Set("enum.SubfloorLayers.FirstLayer", "enabled")
                }
                new typings.PrototypeLayerData {
                    state = "pumpManualValve_\(l)"
                    map = Set("enum.SubfloorLayers.FirstLayer", "enabled")
                }
            }
        }
        new typings.GenericVisualizerComponent {
            visuals {
                ["enum.FilterVisuals.Enabled"] {
                    ["enabled"] {
                        ["True"] {
                            state = "pumpManualValveOn_\(l)"
                        }
                        ["False"] {
                            state = "pumpManualValve_\(l)"
                        }
                    }
                }
            }
        }
        new typings.NodeContainerComponent {
            nodes {
                ["inlet"] = new typings.PipeNode {
                    nodeGroupID = "Pipe"
                    pipeDirection = "North"
                    volume = 100.0
                    layer = l
                }
                ["outlet"] = new typings.PipeNode {
                    nodeGroupID = "Pipe"
                    pipeDirection = "South"
                    volume = 100.0
                    layer = l
                }
            }
        }
        new typings.ConstructionComponent {
            graph = "GasBinary"
            node = "valve\(l)"
        }
    }
}
